# === Supabase (Required — these 3 are mandatory) ===
# WARNING: NEXT_PUBLIC_* vars are exposed to the browser. The anon key
# is safe to expose (RLS enforces access). Keep SERVICE_ROLE_KEY secret.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Database Migration Credentials (scripts only) ===
# SUPABASE_DB_HOST=aws-1-eu-west-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_USER=postgres.your-ref
# SUPABASE_DB_PASSWORD=your-direct-db-password
# SUPABASE_DB_NAME=postgres
# SUPABASE_MGMT_TOKEN=sbp_your-management-token
# SUPABASE_PROJECT_REF=your-project-ref

# === Cloudflare R2 (File Storage) ===
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=<r2-access-key-id>
# R2_SECRET_ACCESS_KEY=<r2-secret-key>
# R2_ASSETS_BUCKET=zamschool-assets
# R2_UPLOADS_BUCKET=zamschool-uploads
# R2_PUBLIC_URL=https://pub-<hash>.r2.dev
# NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-<hash>.r2.dev
# If unset, avatars are served via /api/public/assets/* (uses app bandwidth; enable R2 public URL for production CDN)
# CF_ACCOUNT_ID=<account-id>
# CF_API_TOKEN=<api-token-with-r2-read>
# Public base URL for zamschool-assets (NOT R2_ENDPOINT). Enable in dashboard:
#   R2 → zamschool-assets → Settings → Public Development URL → Enable → copy URL (no trailing slash)
# Format: https://pub-<hash>.r2.dev  — object URLs: {R2_PUBLIC_URL}/{object-key}
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# === Cloudflare Images (Image Optimization) ===
# CLOUDFLARE_IMAGES_ACCOUNT_ID=<account-id>
# CLOUDFLARE_IMAGES_TOKEN=<api-token>
# CLOUDFLARE_IMAGES_ACCOUNT_HASH=<account-hash>
# CLOUDFLARE_IMAGES_DELIVERY_URL=https://imagedelivery.net

# === Cloudflare Gateway Worker ===
# Set this in Vercel production env to route client requests through the Cloudflare Worker edge.
# When unset, the app uses same-origin /api/* directly (fine for local dev).
# NEXT_PUBLIC_GATEWAY_URL=https://zamschool-gateway.<your-account>.workers.dev
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# === Cloudflare KV (Rate Limiting from Next.js server) ===
# KV_REST_API_URL must be the Workers KV REST API endpoint (api.cloudflare.com), NOT the R2 S3 endpoint.
# Correct: https://api.cloudflare.com/client/v4/accounts/<account-id>/storage/kv/namespaces/<namespace-id>
# Wrong:   https://<kv-id>.kv.cloudflarestorage.com  (this is the R2 S3 endpoint — will 404 on every call)
# Create namespace: wrangler kv namespace create RATE_LIMITS
# KV_REST_API_URL=https://api.cloudflare.com/client/v4/accounts/<account-id>/storage/kv/namespaces/<namespace-id>
# KV_REST_API_TOKEN=<api-token-with-kv-read-write>

# === Next.js App URL ===
# Used for invitation links and redirects. Falls back to VERCEL_URL → localhost:3000.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# === Web Origins (CORS) ===
NEXT_PUBLIC_WEBAPP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_WEBAPP_PREVIEW_ORIGIN=https://your-preview.vercel.app
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000

# === Upstash Redis (REST API — no TCP connections, ideal for serverless) ===
# Free tier: 500,000 commands/day, 256MB storage.
# Approved: rate limits, role cache (API), session metadata, OTP/temp tokens.
# NOT for: dashboards, student lists, attendance, exam data (use Supabase + in-memory enhanced-cache).
# Full playbook: docs/SUPABASE_PROTECTION_STRATEGY.md
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# === Platform usage limits (free tier protection) ===
# Max outbound messages per user per UTC day (clamped to 3–5).
# DAILY_MESSAGE_LIMIT=5

# === Email (two channels) ===
# 1) Supabase Dashboard → Authentication → SMTP: password reset & magic links
#    Add redirect URL: {NEXT_PUBLIC_APP_URL}/auth/callback
# 2) App SMTP (below): OTP verification, staff invites, temporary passwords
# OTP_SECRET=long-random-string-required-for-otp-hashing
# RESET_TOKEN_SECRET=long-random-string-for-password-reset-tokens
#   (Optional — falls back to SUPABASE_SERVICE_ROLE_KEY or SMTP_PASS. Fail-closed if none set.)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@your-school-domain.com


# === CDN (optional) ===
# CDN_BASE_URL=https://cdn.yourdomain.com
# CDN_IMAGE_URL=https://cdn.yourdomain.com/images
# CDN_STATIC_URL=https://cdn.yourdomain.com/static

# === Dev / Debug (optional — never enable in production) ===
# ENABLE_UNSAFE_DEV_ROUTES=false

# === Observability (optional but recommended for production) ===
# Structured logging: JSON lines to stdout/stderr in production, readable in dev.
# LOG_LEVEL=info
# Error tracking: forwards captured errors to Sentry when SENTRY_DSN is set.
# Requires `npm install @sentry/node` to activate. Without it, errors are logged only.
# SENTRY_DSN=https://your-key@sentry.io/your-project-id
# SENTRY_TRACES_SAMPLE_RATE=0.1

# === Google AI (optional) ===
# GOOGLE_GENAI_API_KEY=

# === Expo (mobile app origin for images) ===
# EXPO_PUBLIC_WEBAPP_ORIGIN=http://localhost:3000
# EXPO_PUBLIC_WEBAPP_PREVIEW_ORIGIN=https://your-preview.vercel.app


# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
#
# ── Vercel (Next.js server) ─────────────────────────────────────────────────
# Set these in Vercel Dashboard → Settings → Environment Variables:
#
#   NEXT_PUBLIC_SUPABASE_URL        — from Supabase dashboard
#   NEXT_PUBLIC_SUPABASE_ANON_KEY   — from Supabase dashboard
#   SUPABASE_SERVICE_ROLE_KEY       — from Supabase dashboard (keep secret!)
#   UPSTASH_REDIS_REST_URL          — from Upstash console
#   UPSTASH_REDIS_REST_TOKEN        — from Upstash console
#   R2_ENDPOINT                     — https://<account-id>.r2.cloudflarestorage.com
#   R2_ACCESS_KEY_ID                — R2 API token
#   R2_SECRET_ACCESS_KEY            — R2 API token
#   R2_PUBLIC_URL                   — https://pub-<hash>.r2.dev
#   NEXT_PUBLIC_R2_PUBLIC_URL       — same as R2_PUBLIC_URL
#   CLOUDFLARE_IMAGES_ACCOUNT_ID    — Cloudflare account ID
#   CLOUDFLARE_IMAGES_TOKEN         — Cloudflare API token (Images scope)
#   CLOUDFLARE_IMAGES_ACCOUNT_HASH  — from Images dashboard → Delivery URLs
#   KV_REST_API_URL                 — https://api.cloudflare.com/client/v4/accounts/<acc>/storage/kv/<ns>
#   KV_REST_API_TOKEN               — Cloudflare API token (KV scope)
#   NEXT_PUBLIC_GATEWAY_URL         — https://zamschool-gateway.<account>.workers.dev
#   CORS_ALLOWED_ORIGINS            — https://yourdomain.com,http://localhost:3000
#   NEXT_PUBLIC_APP_URL             — https://yourdomain.com
#   NEXT_PUBLIC_WEBAPP_ORIGIN       — https://yourdomain.com
#   NEXT_PUBLIC_APP_ORIGIN          — https://yourdomain.com
#   NEXT_PUBLIC_WEB_ORIGIN          — https://yourdomain.com
#   SMTP_HOST, SMTP_PORT, etc.      — for email sending
#   OTP_SECRET                      — random string for OTP hashing
#
# ── Cloudflare Worker (edge gateway) ────────────────────────────────────────
# 1. Create KV namespaces:
#      node --env-file=.env.local scripts/run-wrangler-with-env.mjs -- kv namespace create SESSION_CACHE
#      node --env-file=.env.local scripts/run-wrangler-with-env.mjs -- kv namespace create RATE_LIMITS
# 2. Update workers/gateway/wrangler.toml with the returned IDs.
# 3. Set JWT secret:
#      echo "<supabase-jwt-secret>" | wrangler secret put SUPABASE_JWT_SECRET
# 4. Deploy:
#      node --env-file=.env.local scripts/run-wrangler-with-env.mjs -- deploy
# 5. Set NEXT_PUBLIC_GATEWAY_URL in Vercel to the deployed worker URL.
#
# ── Cloudflare Images ───────────────────────────────────────────────────────
# Get the account hash from: Dashboard → Images → Overview → Delivery URLs
# The hash is the string after imagedelivery.net/ in the URL.
# Set CLOUDFLARE_IMAGES_ACCOUNT_HASH in both .env.local and Vercel.
#
# ── Upstash Redis ───────────────────────────────────────────────────────────
# Free tier: 500,000 commands/day, 256MB storage.
# Approved prefixes: rl:, role:, sess:, tmp:, daily:, shell:, ws:
# NOT for: dashboards, student lists, attendance, exam data.
# Circuit breaker: 5 failures → open for 30s → auto-recover.
# ============================================================================
