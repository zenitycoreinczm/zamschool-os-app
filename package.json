{
  "name": "zamschool-os",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -H 0.0.0.0 -p 3000",
    "dev:restart": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-server.ps1",
    "build": "next build --webpack",
    "postbuild": "node ./scripts/prepare-standalone.mjs",
    "prestart": "node ./scripts/prepare-standalone.mjs",
    "start": "node --env-file=.env.local ./scripts/start-standalone.mjs",
    "test": "node ./scripts/run-tests.mjs",
    "test:all": "node ./scripts/run-tests.mjs",
    "test:security": "node ./scripts/security/audit-service-role-tenant.mjs && node --test --test-force-exit workers/gateway/src/auth.test.mjs workers/gateway/src/rate-limit.test.mjs && node node_modules/tsx/dist/cli.mjs --test --test-force-exit __tests__/app/api/auth/mfa/route.test.mjs __tests__/app/login/session-switch.test.mjs __tests__/app/api/files/route.test.mjs",
    "lint": "eslint .",
    "clean": "rm -rf .next .next_broken_*",
    "healthcheck": "node ./scripts/healthcheck.mjs",
    "schema:check": "node ./scripts/schema-check.mjs",
    "schema:check:strict": "node ./scripts/schema-check.mjs --strict",
    "audit:tenant": "node ./scripts/security/audit-service-role-tenant.mjs",
    "audit:tenant:strict": "node ./scripts/security/audit-service-role-tenant.mjs --strict",
    "audit:routes": "node ./scripts/audit-route-coverage.mjs",
    "audit:refresh": "node ./scripts/audit-refresh.mjs",
    "cloudflare:status": "node --env-file=.env.local ./scripts/connect-cloudflare.mjs",
    "cloudflare:cache-rules": "node --env-file=.env.local ./scripts/cloudflare-cache-rules.mjs",
    "cloudflare:discover-r2": "node --env-file=.env.local ./scripts/discover-r2-public-url.mjs",
    "cloudflare:r2-test": "node --env-file=.env.local ./scripts/test-avatar-r2.mjs",
    "cdn:preflight": "node node_modules/tsx/dist/cli.mjs --env-file=.env.local ./scripts/cdn-preflight.mjs",
    "cdn:discover": "node --env-file=.env.local ./scripts/discover-r2-public-url.mjs",
    "load:test:smoke": "node node_modules/tsx/dist/cli.mjs ./scripts/load-test/run-load-test.mjs --tier smoke",
    "load:test:tier1": "node node_modules/tsx/dist/cli.mjs ./scripts/load-test/run-load-test.mjs --tier tier1_100",
    "load:test:tier2": "node node_modules/tsx/dist/cli.mjs ./scripts/load-test/run-load-test.mjs --tier tier2_500",
    "load:test:tier3": "node node_modules/tsx/dist/cli.mjs ./scripts/load-test/run-load-test.mjs --tier tier3_1000",
    "load:test:dry": "node node_modules/tsx/dist/cli.mjs ./scripts/load-test/run-load-test.mjs --tier smoke --dry-run",
    "pilot:preflight": "node node_modules/tsx/dist/cli.mjs ./scripts/pilot/preflight.mjs",
    "pilot:log-incident": "node ./scripts/pilot/log-incident.mjs",
    "production:sign-off": "node node_modules/tsx/dist/cli.mjs ./scripts/production/sign-off-preflight.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/papaparse": "^5.5.2",
    "@upstash/redis": "^1.38.0",
    "autoprefixer": "^10.4.21",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "nanoid": "^5.1.6",
    "next": "^16.2.6",
    "nodemailer": "^8.0.2",
    "otplib": "^13.4.0",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-calendar": "^6.0.0",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.6",
    "pg": "^8.20.0",
    "tailwindcss": "4.1.11",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "protobufjs": ">=7.2.5",
    "rimraf": "^4.0.0",
    "@tootallnate/once": ">=3.0.1"
  },
  "optionalDependencies": {
    "lightningcss-win32-x64-msvc": "^1.32.0"
  }
}
